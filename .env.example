# === Корень (для docker-compose) ===
DB_USER=algo_user
DB_PASSWORD=algo_password
DB_NAME=algorithms_db

OPENAI_API_KEY=replace-with-your-openai-compatible-api-key
OPENAI_MODEL=gpt-4o-mini

GIGACHAT_CLIENT_ID=replace-with-your-gigachat-client-id
GIGACHAT_CLIENT_SECRET=replace-with-your-gigachat-client-secret
GIGACHAT_SCOPE=GIGACHAT_API_PERS

JWT_SECRET=change-me-to-a-real-secret-at-least-32-chars!!
JWT_EXPIRES_IN=7d

CLIENT_URL=http://localhost
VITE_API_URL=http://localhost:3001

LOG_LEVEL=info

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX=20

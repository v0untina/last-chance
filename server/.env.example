# === Server ===
NODE_ENV=development
PORT=3001
LOG_LEVEL=info
CLIENT_URL=http://localhost:5173

# === Database (PostgreSQL 15) ===
DATABASE_URL=postgresql://algo_user:algo_password@localhost:5432/algorithms_db
SHADOW_DATABASE_URL=postgresql://algo_user:algo_password@localhost:5432/algorithms_shadow

# === JWT ===
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-me-with-openssl-rand-hex-32
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# === OpenAI (primary AI provider) ===
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=300
OPENAI_TIMEOUT_MS=30000

# === GigaChat (fallback AI provider) ===
GIGACHAT_CLIENT_ID=...
GIGACHAT_CLIENT_SECRET=...
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat:latest
GIGACHAT_TIMEOUT_MS=30000

# === Rate limiting ===
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX=20

# === Caching (AI responses LRU) ===
AI_CACHE_MAX=1000
AI_CACHE_TTL_MS=3600000

# === Circuit breaker ===
CIRCUIT_BREAKER_THRESHOLD=3
CIRCUIT_BREAKER_TIMEOUT_MS=60000
